{
  "name": "pg",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start:auth": "nest start auth --watch",
    "start:config": "nest start config --watch",
    "start:transaction": "nest start transaction --watch",
    "start:settlerecon": "nest start settlerecon --watch",
    "build:auth": "nest build auth",
    "build:config": "nest build config",
    "build:transaction": "nest build transaction",
    "build:settlerecon": "nest build settlerecon",
    "prisma:generate:auth": "dotenv -e apps/auth/.env.local -- prisma generate --schema apps/auth/prisma/schema.prisma",
    "prisma:generate:config": "dotenv -e apps/config/.env -- prisma generate --schema apps/config/prisma/schema.prisma",
    "prisma:generate:transaction": "dotenv -e apps/transaction/.env -- prisma generate --schema apps/transaction/prisma/schema.prisma",
    "prisma:generate:settlerecon": "dotenv -e apps/settlerecon/.env -- prisma generate --schema apps/settlerecon/prisma/schema.prisma",
    "prisma:migrate:dev:auth": "dotenv -e apps/auth/.env -- prisma migrate dev --schema apps/auth/prisma/schema.prisma",
    "prisma:migrate:deploy:auth": "dotenv -e apps/auth/.env -- prisma migrate deploy --schema apps/auth/prisma/schema.prisma",
    "prisma:migrate:dev:config": "dotenv -e apps/config/.env -- prisma migrate dev --schema apps/config/prisma/schema.prisma",
    "prisma:migrate:deploy:config": "dotenv -e apps/config/.env -- prisma migrate deploy --schema apps/config/prisma/schema.prisma",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/pg/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/pg/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.28",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "luxon": "^3.7.2",
    "nestjs-cls": "^6.2.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.2",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/configuration(|/.*)$": "<rootDir>/libs/configuration/src/$1",
      "^@app/date-time(|/.*)$": "<rootDir>/libs/date-time/src/$1"
    }
  }
}
